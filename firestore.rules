rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isRestaurantOwner() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/restaurantOwners/$(request.auth.uid));
    }

    function isOptionalString(value, maxLen) {
      return !(value is string) || value.size() <= maxLen;
    }

    function userCreateSchemaIsValid() {
      return request.resource.data.keys().hasOnly([
        'name',
        'email',
        'photoURL',
        'createdAt'
      ])
      && (!('name' in request.resource.data) || isOptionalString(request.resource.data.name, 100))
      && (!('email' in request.resource.data) || isOptionalString(request.resource.data.email, 320))
      && (!('photoURL' in request.resource.data) || isOptionalString(request.resource.data.photoURL, 1000))
      && ('createdAt' in request.resource.data);
    }

    function userUpdateSchemaIsValid() {
      return request.resource.data.keys().hasOnly([
        'name',
        'email',
        'photoURL',
        'createdAt'
      ])
      && request.resource.data.createdAt == resource.data.createdAt
      && (!('name' in request.resource.data) || isOptionalString(request.resource.data.name, 100))
      && (!('email' in request.resource.data) || isOptionalString(request.resource.data.email, 320))
      && (!('photoURL' in request.resource.data) || isOptionalString(request.resource.data.photoURL, 1000));
    }

    match /users/{uid} {
      allow read: if isUser(uid);

      allow create: if isUser(uid)
                    && userCreateSchemaIsValid();

      allow update: if isUser(uid)
                    && userUpdateSchemaIsValid();

      allow delete: if false;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.branchId == request.auth.uid ||
        isAdmin() ||
        (
          isRestaurantOwner() &&
          resource.data.restaurantId ==
            get(/databases/$(database)/documents/restaurantOwners/$(request.auth.uid)).data.restaurantId
        )
      );

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /restaurantOwners/{ownerId} {
      allow read: if isSignedIn() && (
        request.auth.uid == ownerId ||
        isAdmin()
      );

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (
        request.auth.uid == adminId ||
        isAdmin()
      );

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /offers/{offerId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /restaurants/{restaurantId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /_rateLimits/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
