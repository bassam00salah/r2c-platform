// Firestore Security Rules — R2C Platform (Production)
//
// مبدأ الحد الأدنى من الصلاحيات:
//   - المستخدم: يقرأ فقط بياناته + العروض المتاحة + الفروع
//   - الفرع (partner): يقرأ ويكتب طلباته فقط عبر Cloud Functions
//   - الأدمن: يصل لكل شيء (مع التحقق من مستند admins)
//   - تحديثات الطلبات الحساسة: ممنوعة من العميل — تمر عبر Cloud Functions فقط

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isBranch(branchId) {
      return isAuth() && request.auth.uid == branchId;
    }

    // الحقول الحساسة التي يُمنع العميل من كتابتها مباشرة
    function noSensitiveOrderFields() {
      return !request.resource.data.keys().hasAny([
        'status', 'price', 'qrCode', 'userId', 'branchId',
        'completedAt', 'acceptedAt', 'rejectedAt', 'readyAt'
      ]);
    }

    // ─── users ───────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isUser(uid) || isAdmin();
      allow create: if isUser(uid);
      allow update: if isUser(uid) && noSensitiveOrderFields();
    }

    // ─── orders ──────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // القراءة: مالك الطلب أو الفرع المعيَّن أو الأدمن
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        resource.data.branchId == request.auth.uid ||
        isAdmin()
      );

      // الإنشاء: ممنوع من العميل — عبر createOrder Cloud Function فقط
      allow create: if false;

      // التحديث: ممنوع من العميل — عبر updateOrderStatus / cancelOrderOnTimeout فقط
      allow update: if false;

      // الحذف: الأدمن فقط
      allow delete: if isAdmin();
    }

    // ─── branches ────────────────────────────────────────────────────────
    match /branches/{branchId} {
      // القراءة: أي مستخدم مسجَّل (لعرض الفروع القريبة)
      allow read: if isAuth();

      // الكتابة: ممنوع من العميل — عبر createBranchUser Cloud Function فقط
      allow write: if false;
    }

    // ─── offers ──────────────────────────────────────────────────────────
    match /offers/{offerId} {
      allow read: if isAuth();
      // الكتابة: الأدمن فقط (من لوحة الإدارة)
      allow write: if isAdmin();
    }

    // ─── restaurants ─────────────────────────────────────────────────────
    match /restaurants/{restaurantId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── restaurantOwners ────────────────────────────────────────────────
    match /restaurantOwners/{uid} {
      allow read: if isUser(uid) || isAdmin();
      allow write: if false; // عبر createOwnerUser Cloud Function فقط
    }

    // ─── admins ──────────────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if isUser(uid) || isAdmin();
      allow write: if false; // يُكتب يدوياً في Firebase Console فقط
    }

    // ─── _rateLimits ─────────────────────────────────────────────────────
    match /_rateLimits/{docId} {
      allow read, write: if false; // Cloud Functions فقط
    }

    // ─── منع أي وصول غير مُعرَّف ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
