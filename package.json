{
  "name": "r2c-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:user": "npm -w apps/user run dev",
    "dev:partner": "npm -w apps/partner run dev",
    "dev:admin": "npm -w apps/admin run dev",
    "build:user": "npm -w apps/user run build",
    "build:all": "npm -w apps/user run build && npm -w apps/partner run build && npm -w apps/admin run build"
  },
  "dependencies": {
    "html5-qrcode": "^2.3.8"
  }
}
