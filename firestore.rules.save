service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // دوال مساعدة
    // ─────────────────────────────────────────────

    // هل المستخدم أدمن؟
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // هل المستخدم هو صاحب الوثيقة؟
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // هل المستخدم فرع مسجل؟
    function isBranch() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/branches/$(request.auth.uid));
    }

    // هل الحقل لم يتغير؟
    function fieldUnchanged(field) {
      return !(field in request.resource.data) ||
        request.resource.data[field] == resource.data[field];
    }


    // ─────────────────────────────────────────────
    // المستخدمون /users/{userId}
    // ─────────────────────────────────────────────
    match /users/{userId} {
      // المستخدم يقرأ ويعدل بياناته فقط — الأدمن يقرأ الكل
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && isAdmin() == false
                      // لا يسمح للمستخدم بتعديل uid أو email
                      && fieldUnchanged('email');
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // الأدمن /admins/{adminId}
    // ─────────────────────────────────────────────
    match /admins/{adminId} {
  		// الأدمن يقرأ وثيقته هو فقط (للتحقق من الدور)
  		allow read: if request.auth != null && request.auth.uid == adminId;
  		// لا أحد يكتب من العميل — فقط Firebase Console
  		allow write: if false;
		}


    // ─────────────────────────────────────────────
    // المطاعم /restaurants/{restaurantId}
    // ─────────────────────────────────────────────
    match /restaurants/{restaurantId} {
      // الكل يقرأ المطاعم النشطة — الأدمن فقط يكتب
      allow read:  if resource.data.status == 'active' || isAdmin();
      allow write: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // الفروع /branches/{branchId}
    // ─────────────────────────────────────────────
    match /branches/{branchId} {
      // العملاء يقرؤون الفروع النشطة لحساب أقرب فرع
      allow read: if resource.data.status == 'active' || isAdmin() || isOwner(branchId);

      // الأدمن فقط ينشئ فروعاً
      allow create: if isAdmin();

      // الفرع يعدل بياناته هو فقط — بقيود صارمة
      allow update: if (isOwner(branchId) && (
                        // الفرع يعدل فقط الحقول المسموح بها
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['name','address','phone','workingHours','latitude','longitude',
                                    'isSetupComplete','settings'])
                        // لا يسمح للفرع بتغيير restaurantId أو branchEmail
                        && fieldUnchanged('restaurantId')
                        && fieldUnchanged('branchEmail')
                        // settings: الفرع يعدل acceptingOrders فقط (autoAcceptTime يحدده الأدمن)
                      )) || isAdmin();

      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // العروض /offers/{offerId}
    // ─────────────────────────────────────────────
    match /offers/{offerId} {
      // الكل يقرأ العروض النشطة
      allow read:  if resource.data.status == 'active' || isAdmin();
      // الأدمن فقط يكتب
      allow write: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // الطلبات /orders/{orderId}  ← الأهم
    // ─────────────────────────────────────────────
    match /orders/{orderId} {

      // القراءة: المستخدم صاحب الطلب، أو الفرع المعين، أو الأدمن
      allow read: if isAdmin()
                  || (request.auth != null && resource.data.userId == request.auth.uid)
                  || (request.auth != null && resource.data.branchId == request.auth.uid);

      // الإنشاء: المستخدم المسجل فقط — مع قيود صارمة
      allow create: if request.auth != null
                    // يجب أن يكون userId هو المستخدم الحالي (لا طلبات مجهولة)
                    && request.resource.data.userId == request.auth.uid
                    // الحالة الابتدائية دائماً preparing
                    && request.resource.data.status == 'preparing'
                    // لا يسمح بتحديد qrCode يدوياً — يجب أن يبدأ بـ QR-
                    && request.resource.data.qrCode.matches('QR-[A-F0-9]+')
                    // branchId مطلوب
                    && request.resource.data.branchId is string
                    && request.resource.data.branchId.size() > 0;

      // التحديث: قيود صارمة على من يعدل ماذا
      allow update: if isAdmin()
                    // المستخدم يلغي طلبه فقط (user_cancelled) — ولا يغير أي حقل آخر
                    || (request.auth != null
                        && resource.data.userId == request.auth.uid
                        && request.resource.data.status == 'rejected'
                        && request.resource.data.rejectedReason == 'user_cancelled'
                        // لا يسمح بتغيير qrCode أبداً بعد الإنشاء
                        && fieldUnchanged('qrCode')
                        && fieldUnchanged('userId')
                        && fieldUnchanged('branchId')
                        && fieldUnchanged('price'))
                    // الفرع يقبل أو يرفض أو يُجهز طلبات فرعه فقط
                    || (request.auth != null
                        && resource.data.branchId == request.auth.uid
                        // الفرع لا يغير userId أو qrCode أو السعر
                        && fieldUnchanged('qrCode')
                        && fieldUnchanged('userId')
                        && fieldUnchanged('price')
                        && fieldUnchanged('branchId'));

      // لا أحد يحذف الطلبات من العميل
      allow delete: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // إعدادات النظام /system/{docId}
    // ─────────────────────────────────────────────
    match /system/{docId} {
      // الكل يقرأ الإعدادات العامة (المدن، الإحصاءات)
      allow read: if request.auth != null;
      // الأدمن فقط يكتب
      allow write: if isAdmin();
    }


    // ─────────────────────────────────────────────
    // المؤثرون /influencers/{id}
    // ─────────────────────────────────────────────
    match /influencers/{id} {
      allow read, write: if isAdmin();
    }

  }
}
